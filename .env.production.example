# =========================================================
# SMOLSManager Production Environment
# =========================================================

NODE_ENV=production
PORT=3000
LOG_LEVEL=warn

# =========================================================
# DATABASE
# =========================================================

POSTGRES_DB=smolsmanager
POSTGRES_USER=smols
POSTGRES_PASSWORD=change_this_secure_password

DATABASE_URL=postgresql://smols:change_this_secure_password@postgres:5432/smolsmanager?schema=public

# =========================================================
# JWT
# =========================================================

JWT_SECRET=change_this_super_long_random_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# =========================================================
# DOMAINS
# =========================================================

SMOLS_PUBLIC_URL=https://smolsmanager.com
SMOLS_API_URL=https://api.smolsmanager.com
